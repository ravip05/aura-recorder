{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["chrome"],
    "outDir": ".",
    "rootDir": ".",
    "isolatedModules": false
  },
  "include": [
    "background.ts",
    "shared/**/*.ts",
    "popup/**/*.ts",
    "canvas/**/*.ts",
    "content/**/*.ts",
    "offscreen/**/*.ts",
    "player/**/*.ts",
    "camera/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
